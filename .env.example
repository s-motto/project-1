# ==========================================
# LET'S WALK - Environment Variables
# ==========================================
# Copia questo file come .env e compila i valori
# ==========================================

# Appwrite Configuration
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=
VITE_APPWRITE_DATABASE_ID=
VITE_APPWRITE_ROUTES_COLLECTION_ID=
VITE_APPWRITE_FUNCTION_ID=

# OpenRouteService (SOLO per development/testing locale)
# In produzione la chiave è gestita dalla Appwrite Function
VITE_OPENROUTE_API_KEY=

# MapTiler (per immagini statiche dei percorsi)
VITE_MAPTILER_KEY=

# Tile Server (fallback se MapTiler non disponibile)
VITE_STATIC_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_TILE_ATTRIBUTION=© OpenStreetMap contributors